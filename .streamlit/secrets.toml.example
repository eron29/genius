# Copie este arquivo para .streamlit/secrets.toml para uso local,
# ou cole o conteúdo em "Settings > Secrets" no Streamlit Community Cloud.
# NUNCA faça commit do arquivo secrets.toml real (ele já está no .gitignore).
#
# A app detecta sozinha o provedor a usar com base em qual chave existe aqui
# (ordem de checagem: Groq, OpenAI, Gemini). Basta preencher a(s) que você já tem.

OPENAI_API_KEY = "sua-chave-openai-aqui"
GROQ_API_KEY = "sua-chave-groq-aqui"
GEMINI_API_KEY = "sua-chave-gemini-aqui"
